          <grid cols="3" gap="m">

            <!-- row 1 -->
            <frame background="surface-alt" border="xs card-border" padding="m" radius="s">
              <stack gap="s">
                <flank gap="s" align="center" end="true">
                  <text font-size="m" font="Helvetica-Bold" color="text">Single Sign-On</text>
                  <frame background="badge-bg" padding="xs" radius="xs">
                    <text font-size="xs" font="Helvetica-Bold" color="badge-text">Security</text>
                  </frame>
                </flank>
                <text font-size="s" color="text-muted">Connect any SAML 2.0 or OIDC identity provider in minutes with no custom code.</text>
              </stack>
            </frame>

            <frame background="surface-alt" border="xs card-border" padding="m" radius="s">
              <stack gap="s">
                <flank gap="s" align="center" end="true">
