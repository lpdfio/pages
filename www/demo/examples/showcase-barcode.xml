<lpdf version="1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../../schema/lpdf.xsd">
  <tokens>
    <colors>
      <color name="primary"  value="#1763cf" />
      <color name="surface"  value="#ffffff" />
      <color name="bg"       value="#f5f7fa" />
      <color name="accent"   value="#e8f0fc" />
      <color name="muted"    value="#737373" />
      <color name="rule"     value="#dde3ed" />
    </colors>
  </tokens>
  <document size="a4" margin="40pt">
    <meta title="lpdf Showcase — Barcodes" subject="QR Code · Code 128 · EAN-13" />

      <section background="surface">
        <layout>
        <stack gap="xl">

          <stack gap="xs">
            <text font-size="xxl" font="Helvetica-Bold" color="primary">Barcodes</text>
            <text font-size="m" color="muted">Vector barcodes rendered as filled PDF rectangles — fully resolution-independent</text>
          </stack>

          <!-- QR Code -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">QR Code</text>

            <stack gap="xs">
              <text font-size="m" color="muted">Default error-correction (M) — size 80pt</text>
              <barcode type="qr" data="https://lpdf.dev" size="80pt" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">Error-correction H — size 100pt, custom colour</text>
              <barcode type="qr" data="https://lpdf.dev" ec="H" size="100pt" color="#1763cf" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">With background — ec=L, size 80pt</text>
              <barcode type="qr" data="Hello, lpdf!" ec="L" size="80pt"
                       color="#1a1a1a" background="#fff9e6" />
            </stack>

            <flank gap="m">
              <stack gap="xs">
                <text font-size="s" color="muted">ec=L</text>
                <barcode type="qr" data="lpdf" ec="L" size="60pt" />
              </stack>
              <stack gap="xs">
                <text font-size="s" color="muted">ec=M</text>
                <barcode type="qr" data="lpdf" ec="M" size="60pt" />
              </stack>
              <stack gap="xs">
                <text font-size="s" color="muted">ec=Q</text>
                <barcode type="qr" data="lpdf" ec="Q" size="60pt" />
              </stack>
              <stack gap="xs">
                <text font-size="s" color="muted">ec=H</text>
                <barcode type="qr" data="lpdf" ec="H" size="60pt" />
              </stack>
            </flank>
          </stack>

          <!-- Code 128 -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">Code 128</text>

            <stack gap="xs">
              <text font-size="m" color="muted">Default — width 200pt, height 40pt</text>
              <barcode type="code128" data="ABC-12345" width="200pt" height="40pt" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">With HRT (human-readable text)</text>
              <barcode type="code128" data="ABC-12345" width="200pt" height="40pt" hrt="true" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">Narrow bars — width 160pt, height 30pt, custom colour</text>
              <barcode type="code128" data="Lpdf-2024" width="160pt" height="30pt"
                       color="#b00020" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">With background and HRT</text>
              <barcode type="code128" data="CODE128" width="200pt" height="40pt"
                       hrt="true" color="#003366" background="#e8f0fc" />
            </stack>
          </stack>

          <!-- EAN-13 -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">EAN-13</text>

            <stack gap="xs">
              <text font-size="m" color="muted">12-digit input — check digit computed automatically</text>
              <barcode type="ean13" data="590123412345" width="140pt" height="60pt" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">With HRT</text>
              <barcode type="ean13" data="590123412345" width="140pt" height="60pt" hrt="true" />
            </stack>

            <stack gap="xs">
              <text font-size="m" color="muted">Custom colour</text>
              <barcode type="ean13" data="012345678905" width="140pt" height="60pt"
                       color="#1763cf" />
            </stack>

            <flank gap="xl" align="start">
              <stack gap="xs">
                <text font-size="s" color="muted">First digit 0 — LLLLLL parity</text>
                <barcode type="ean13" data="012345678905" width="120pt" height="50pt" />
              </stack>
              <stack gap="xs">
                <text font-size="s" color="muted">First digit 5 — LGGLLG parity</text>
                <barcode type="ean13" data="590123412345" width="120pt" height="50pt" />
              </stack>
            </flank>
          </stack>

        </stack>
        </layout>
      </section>

      <!-- Inline in layouts -->
      <section background="surface">
        <layout>
        <stack gap="xl">

          <stack gap="xs">
            <text font-size="xxl" font="Helvetica-Bold" color="primary">Barcodes in Layouts</text>
            <text font-size="m" color="muted">Barcodes compose naturally with stack, flank, frame, and cluster</text>
          </stack>

          <!-- Side-by-side in a card -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">Card with QR</text>
            <frame background="bg" padding="m" radius="4pt" border="s #dde3ed">
              <flank gap="l" align="center">
                <stack gap="xs">
                  <text font-size="l" font="Helvetica-Bold">Product Label</text>
                  <text font-size="m" color="muted">SKU: LP-2024-001</text>
                  <text font-size="m" color="muted">Scan to view details online</text>
                </stack>
                <barcode type="qr" data="https://lpdf.dev/products/LP-2024-001"
                         ec="M" size="80pt" />
              </flank>
            </frame>
          </stack>

          <!-- Shipping label style -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">Shipping Label Style</text>
            <frame background="surface" padding="m" radius="2pt" border="s #000000">
              <stack gap="s">
                <text font-size="l" font="Helvetica-Bold" align="center">PRIORITY MAIL</text>
                <divider color="#000000" thickness="2pt" />
                <text font-size="s" color="muted">SHIP TO:</text>
                <text font-size="m" font="Helvetica-Bold">John Doe</text>
                <text font-size="m">123 Main Street, Anytown, CA 90210</text>
                <divider color="#dde3ed" />
                <barcode type="code128" data="1Z999AA10123456784"
                         height="50pt" hrt="true" />
              </stack>
            </frame>
          </stack>

          <!-- EAN-13 in a product grid -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">Product Barcodes</text>
            <flank gap="m">
              <frame background="bg" padding="s" radius="3pt">
                <stack gap="xs" align="center">
                  <text font-size="s" font="Helvetica-Bold" align="center">Product A</text>
                  <barcode type="ean13" data="012345678905" width="100pt" height="45pt" hrt="true" />
                </stack>
              </frame>
              <frame background="bg" padding="s" radius="3pt">
                <stack gap="xs" align="center">
                  <text font-size="s" font="Helvetica-Bold" align="center">Product B</text>
                  <barcode type="ean13" data="590123412345" width="100pt" height="45pt" hrt="true" />
                </stack>
              </frame>
              <frame background="bg" padding="s" radius="3pt">
                <stack gap="xs" align="center">
                  <text font-size="s" font="Helvetica-Bold" align="center">Product C</text>
                  <barcode type="ean13" data="400638133393" width="100pt" height="45pt" hrt="true" />
                </stack>
              </frame>
            </flank>
          </stack>

        </stack>
        </layout>
      </section>
  </document>
</lpdf>
