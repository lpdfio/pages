<lpdf version="1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../../schema/lpdf.xsd">
  <assets>
    <font  name="montserrat" ref="font" src="../assets/Montserrat-Regular.ttf" />
    <image name="logo"       ref="logo" src="../assets/logo-lpdf.png" />
  </assets>
  <tokens>
    <colors>
      <color name="primary"  value="#1763cf" />
      <color name="surface"  value="#ffffff" />
      <color name="bg"       value="#f5f7fa" />
      <color name="accent"   value="#e8f0fc" />
      <color name="muted"    value="#737373" />
      <color name="rule"     value="#dde3ed" />
    </colors>
  </tokens>
  <document size="a4" margin="40pt">
    <meta title="lpdf Showcase — Assets" subject="Custom fonts and images" />

      <!-- Assets -->
      <section background="surface">
        <layout>
        <stack gap="xl">

          <stack gap="xs">
            <text font-size="xxl" font="Helvetica-Bold" color="primary">Assets</text>
            <text font-size="m" color="muted">Loading custom fonts and images via src= in &lt;assets&gt;</text>
          </stack>

          <!-- font -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">font</text>
            <stack gap="xs">
              <text font-size="m" color="muted">font="montserrat" at various sizes</text>
              <stack gap="s" background="bg" padding="m">
                <text font="montserrat" font-size="xs">xs — The quick brown fox jumps over the lazy dog</text>
                <text font="montserrat" font-size="s">s — The quick brown fox jumps over the lazy dog</text>
                <text font="montserrat" font-size="m">m — The quick brown fox jumps over the lazy dog</text>
                <text font="montserrat" font-size="l">l — The quick brown fox</text>
                <text font="montserrat" font-size="xl">xl — The quick brown fox</text>
                <text font="montserrat" font-size="xxl">xxl — lpdf</text>
              </stack>
            </stack>
            <stack gap="xs">
              <text font-size="m" color="muted">mixed with a built-in font in the same paragraph</text>
              <stack background="bg" padding="m">
                <text font-size="m">This sentence uses <span font="montserrat">Montserrat for the custom part</span> and the default Helvetica elsewhere.</text>
              </stack>
            </stack>
            <stack gap="xs">
              <text font-size="m" color="muted">document-level font="montserrat" — all text inherits the custom font</text>
              <stack gap="s" background="bg" padding="m" font="montserrat">
                <text font-size="m">Paragraph one set entirely in Montserrat.</text>
                <text font-size="m" color="muted">Paragraph two also in Montserrat, with the muted color token applied.</text>
              </stack>
            </stack>
          </stack>

          <!-- image -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">image</text>
            <stack gap="xs">
              <text font-size="m" color="muted">width token scale</text>
              <flank gap="m" background="bg" padding="m" align="center">
                <stack gap="xs" align="center">
                  <img name="logo" width="24pt" />
                  <text font-size="xs" color="muted">24pt</text>
                </stack>
                <stack gap="xs" align="center">
                  <img name="logo" width="40pt" />
                  <text font-size="xs" color="muted">40pt</text>
                </stack>
                <stack gap="xs" align="center">
                  <img name="logo" width="64pt" />
                  <text font-size="xs" color="muted">64pt</text>
                </stack>
                <stack gap="xs" align="center">
                  <img name="logo" width="96pt" />
                  <text font-size="xs" color="muted">96pt</text>
                </stack>
              </flank>
            </stack>
            <stack gap="xs">
              <text font-size="m" color="muted">height constraint (width scales proportionally)</text>
              <flank gap="m" background="bg" padding="m" align="center">
                <stack gap="xs" align="center">
                  <img name="logo" height="24pt" />
                  <text font-size="xs" color="muted">h=24pt</text>
                </stack>
                <stack gap="xs" align="center">
                  <img name="logo" height="48pt" />
                  <text font-size="xs" color="muted">h=48pt</text>
                </stack>
                <stack gap="xs" align="center">
                  <img name="logo" height="72pt" />
                  <text font-size="xs" color="muted">h=72pt</text>
                </stack>
              </flank>
            </stack>
          </stack>

          <!-- combined -->
          <stack gap="m">
            <text font-size="l" font="Helvetica-Bold">combined</text>
            <stack gap="xs">
              <text font-size="m" color="muted">logo + Montserrat in a page header</text>
              <flank gap="m" padding="m" border="xs rule" radius="xs" align="center">
                <img name="logo" height="32pt" />
                <stack gap="xs">
                  <text font="montserrat" font-size="l" color="primary">lpdf</text>
                  <text font="montserrat" font-size="s" color="muted">Declarative PDF layout engine</text>
                </stack>
                <text font="montserrat" font-size="s" color="muted">v1.0</text>
              </flank>
            </stack>
          </stack>

        </stack>
        </layout>
      </section>
  </document>
</lpdf>
