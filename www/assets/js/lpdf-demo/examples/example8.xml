<lpdf version="1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../../schema/lpdf.xsd">
  <tokens>
    <colors>
      <color name="primary"     value="#2563eb" />
      <color name="surface"     value="#ffffff" />
      <color name="surface-alt" value="#f1f5f9" />
      <color name="card-border" value="#e2e8f0" />
      <color name="text"        value="#0f172a" />
      <color name="text-muted"  value="#64748b" />
      <color name="badge-bg"    value="#dbeafe" />
