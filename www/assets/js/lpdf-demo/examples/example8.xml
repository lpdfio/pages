                    <text font-size="xs" font="Helvetica-Bold" color="badge-text">Compliance</text>
                  </frame>
                </flank>
                <text font-size="s" color="text-muted">Configure per-workspace data lifecycle policies from 30 days to 10 years.</text>
              </stack>
            </frame>

            <!-- row 4 -->
            <frame background="surface-alt" border="xs card-border" padding="m" radius="s">
              <stack gap="s">
                <flank gap="s" align="center" end="true">
                  <text font-size="m" font="Helvetica-Bold" color="text">Priority Support</text>
                  <frame background="badge-bg" padding="xs" radius="xs">
                    <text font-size="xs" font="Helvetica-Bold" color="badge-text">Support</text>
                  </frame>
                </flank>
                <text font-size="s" color="text-muted">Dedicated Slack channel and 4-hour SLA for P1 incidents around the clock.</text>
              </stack>
            </frame>

            <frame background="surface-alt" border="xs card-border" padding="m" radius="s">
              <stack gap="s">
