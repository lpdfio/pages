<lpdf version="1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../../schema/lpdf.xsd">
  <tokens>
    <colors>
      <color name="brand"      value="#1763cf" />
      <color name="surface"    value="#ffffff" />
      <color name="text"       value="#1a1a1a" />
      <color name="text-muted" value="#737373" />
      <color name="rule"       value="#dde3ed" />
    </colors>
  </tokens>
  <!-- Standard business card: 3.5in × 2in = 252pt × 144pt -->
  <document size="252pt 144pt" margin="0pt">
    <meta title="Business Card — Jane Doe" />

      <!-- Front -->
      <section background="brand">
        <layout>
        <stack padding="l" gap="m" height="full" justify="between">

          <!-- name + title -->
          <stack gap="xs">
            <text font-size="l" font="Helvetica-Bold" color="surface">Jane Doe</text>
            <text font-size="s" color="surface">Staff Engineer</text>
          </stack>

          <!-- company -->
          <text font-size="m" font="Helvetica-Bold" color="surface">Acme Corp</text>

        </stack>
        </layout>
      </section>

      <!-- Back -->
      <section background="surface">
        <layout>
        <stack padding="l" gap="m" height="full" justify="between">

          <!-- company repeated small -->
          <text font-size="xs" font="Helvetica-Bold" color="brand">ACME CORP</text>

          <!-- contact details -->
          <stack gap="s">
            <flank gap="s" align="center" end="true">
              <text font-size="s" color="text-muted">Email</text>
              <text font-size="s">jane@acmecorp.example</text>
            </flank>
            <flank gap="s" align="center" end="true">
              <text font-size="s" color="text-muted">Phone</text>
              <text font-size="s">+1 555 000 1234</text>
            </flank>
            <flank gap="s" align="center" end="true">
              <text font-size="s" color="text-muted">Web</text>
              <text font-size="s">acmecorp.example</text>
            </flank>
          </stack>

          <divider color="rule" thickness="xs" />

          <text font-size="xs" color="text-muted">123 Business Ave, Suite 4 · San Francisco, CA 94107</text>

        </stack>
        </layout>
      </section>
  </document>
</lpdf>
