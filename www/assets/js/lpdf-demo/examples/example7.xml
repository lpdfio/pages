<lpdf version="1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="../../schema/lpdf.xsd">
  <tokens>
    <colors>
      <color name="surface"     value="#ffffff" />
      <color name="text"        value="#1a1a1a" />
      <color name="text-muted"  value="#555555" />
      <color name="rule"        value="#cccccc" />
      <color name="priority-bg" value="#e63946" />
    </colors>
  </tokens>
  <!-- 4in × 6in shipping label = 288pt × 432pt -->
  <document size="288pt 432pt" margin="0pt">
    <meta title="Shipping Label — ORD-20260412-0087" />
      <section background="surface">
        <layout>
        <stack gap="0pt" height="full">

          <!-- carrier header -->
          <frame background="text" padding="m">
            <flank gap="m" align="center" end="true">
              <text font-size="xl" font="Helvetica-Bold" color="surface">PRIORITY MAIL</text>
              <frame background="priority-bg" padding="xs" radius="xs">
                <text font-size="s" font="Helvetica-Bold" color="surface">2-DAY</text>
              </frame>
            </flank>
          </frame>

          <!-- ship-from / ship-to -->
          <stack gap="0pt" border="xs rule">

            <!-- from -->
            <frame padding="m" border="xs rule">
              <stack gap="xs">
                <text font-size="xs" font="Helvetica-Bold" color="text-muted">FROM</text>
                <text font-size="s" font="Helvetica-Bold">Acme Corp — Fulfillment Center</text>
                <text font-size="s">789 Warehouse Blvd</text>
                <text font-size="s">Oakland, CA 94601</text>
                <text font-size="s">US</text>
              </stack>
            </frame>

            <!-- to -->
            <frame padding="m">
              <stack gap="xs">
                <text font-size="xs" font="Helvetica-Bold" color="text-muted">SHIP TO</text>
                <text font-size="l" font="Helvetica-Bold">Jane Doe</text>
                <text font-size="m">456 Elm Street, Apt 7B</text>
                <text font-size="m">Austin, TX 78701</text>
                <text font-size="m">US</text>
              </stack>
            </frame>

          </stack>

          <divider color="rule" thickness="s" />

          <!-- barcode placeholder + tracking -->
          <frame padding="m" height="fill">
            <stack gap="s" align="center">
              <frame width="220pt" height="60pt" background="rule" radius="xs" />
              <text font-size="s" font="Courier-Bold">9400 1118 9922 3456 7890 12</text>
            </stack>
          </frame>

          <divider color="rule" thickness="xs" />

          <!-- order details -->
          <frame padding="m">
            <stack gap="s">
              <flank gap="m" align="center" end="true">
                <text font-size="xs" color="text-muted">ORDER</text>
                <text font-size="s" font="Helvetica-Bold">ORD-20260412-0087</text>
              </flank>
              <flank gap="m" align="center" end="true">
                <text font-size="xs" color="text-muted">WEIGHT</text>
                <text font-size="s">1.2 lbs</text>
              </flank>
              <flank gap="m" align="center" end="true">
                <text font-size="xs" color="text-muted">DIMENSIONS</text>
                <text font-size="s">12 × 8 × 4 in</text>
              </flank>
              <flank gap="m" align="center" end="true">
                <text font-size="xs" color="text-muted">SERVICE</text>
                <text font-size="s">Priority Mail 2-Day</text>
              </flank>
            </stack>
          </frame>

          <divider color="rule" thickness="xs" />

          <!-- footer: label date -->
          <frame padding="s">
            <flank gap="m" align="center" end="true">
              <text font-size="xs" color="text-muted">Label created April 12, 2026</text>
              <text font-size="xs" color="text-muted">acmecorp.example/track</text>
            </flank>
          </frame>

        </stack>
        </layout>
      </section>
  </document>
</lpdf>
